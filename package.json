{
  "name": "brothers-remodeling-okc",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build && node scripts/prerender-seo.mjs && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "NODE_ENV=production node dist/index.js",
    "preview": "vite preview --host",
    "check": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@types/express": "4.17.21",
    "@types/node": "24.7.0",
    "@types/react": "19.2.1",
    "@types/react-dom": "19.2.1",
    "@vitejs/plugin-react": "5.0.4",
    "esbuild": "0.25.12",
    "express": "4.22.2",
    "lucide-react": "0.453.0",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "typescript": "5.6.3",
    "vite": "7.3.3",
    "vitest": "4.1.7",
    "wouter": "3.3.5"
  },
  "packageManager": "pnpm@10.15.1",
  "pnpm": {
    "overrides": {
      "tsx>esbuild": "^0.25.12"
    }
  }
}
